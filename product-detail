<!DOCTYPE html>
<html>
<head>

<title>Contact Support - POZARA</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#F5F1EB;
}

/* TOP HEADER */

.top-header{
    background:black;
    color:white;
    text-align:center;
    padding:8px;
    font-size:14px;
}

/* HEADER */

.header{
    background:#F5F1EB;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 50px;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.logo{
    font-size:35px;
    font-weight:bold;
    color:#ff6600;
}

.header-right a{
    text-decoration:none;
    color:black;
    margin-left:20px;
    font-weight:bold;
    transition:0.3s;
}

.header-right a:hover{
    color:red;
}

/* CATEGORY BAR */

.main-categorybar{
    background:black;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:12px 30px;
}

.main-right{
    display:flex;
    gap:30px;
}

.main-right a{
    color:white;
    text-decoration:none;
    font-size:16px;
    font-weight:bold;
    transition:0.3s;
}

.main-right a:hover{
    color:red;
}

/* SEARCH */

.main-center{
    flex-grow:1;
    display:flex;
    justify-content:center;
}

.searchbar{
    display:flex;
}

.searchbar input{
    padding:8px 12px;
    border:none;
    outline:none;
    width:220px;
    border-radius:4px 0 0 4px;
}

.searchbar button{
    border:none;
    background:red;
    color:white;
    padding:8px 15px;
    cursor:pointer;
    border-radius:0 4px 4px 0;
}

/* ICONS */

.main-left{
    display:flex;
    gap:25px;
}

.main-left a{
    color:white;
    font-size:20px;
    transition:0.3s;
}

.main-left a:hover{
    color:red;
    transform:scale(1.2);
}

/* HERO */

.contact-hero{
    text-align:center;
    padding:80px 20px 60px;
}

.contact-hero h1{
    font-size:60px;
    margin-bottom:15px;
}

.contact-hero p{
    color:gray;
    font-size:20px;
}

/* CONTACT SECTION */

.contact-section{
    width:90%;
    max-width:1200px;
    margin:0 auto 90px;
    display:flex;
    gap:40px;
    flex-wrap:wrap;
}

/* LEFT CONTACT INFO */

.contact-info{
    flex:1;
    min-width:300px;
}

.info-card{
    background:white;
    padding:30px;
    border-radius:20px;
    margin-bottom:25px;
    box-shadow:0 5px 18px rgba(0,0,0,0.12);
    display:flex;
    gap:20px;
    align-items:flex-start;
}

.info-card i{
    width:70px;
    height:70px;
    background:black;
    color:white;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:28px;
}

.info-text h2{
    margin-top:0;
    margin-bottom:10px;
}

.info-text p{
    color:gray;
    line-height:1.8;
}

/* CONTACT FORM */

.contact-form{
    flex:1;
    min-width:320px;
    background:white;
    padding:40px;
    border-radius:25px;
    box-shadow:0 5px 18px rgba(0,0,0,0.12);
}

.contact-form h1{
    margin-top:0;
    margin-bottom:35px;
}

/* INPUTS */

.input-group{
    margin-bottom:22px;
}

.input-group label{
    display:block;
    margin-bottom:10px;
    font-weight:bold;
}

.input-group input,
.input-group textarea{
    width:100%;
    padding:15px;
    border:1px solid #ccc;
    border-radius:10px;
    outline:none;
    font-size:15px;
    box-sizing:border-box;
}

.input-group textarea{
    resize:none;
}

/* BUTTON */

.send-btn{
    width:100%;
    border:none;
    background:red;
    color:white;
    padding:16px;
    font-size:18px;
    font-weight:bold;
    border-radius:10px;
    cursor:pointer;
    transition:0.3s;
}

.send-btn:hover{
    background:black;
}

/* SOCIAL */

.social-section{
    text-align:center;
    margin-bottom:80px;
}

.social-section h1{
    font-size:45px;
    margin-bottom:30px;
}

.social-icons{
    display:flex;
    justify-content:center;
    gap:25px;
}

.social-icons a{
    width:65px;
    height:65px;
    background:black;
    color:white;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:28px;
    transition:0.3s;
    text-decoration:none;
}

.social-icons a:hover{
    background:red;
    transform:translateY(-8px);
}

/* MAP SECTION */

.map-section{
    width:90%;
    max-width:1200px;
    margin:0 auto 100px;
}

.map-section h1{
    text-align:center;
    font-size:45px;
    margin-bottom:35px;
}

.map-box{
    background:white;
    border-radius:25px;
    overflow:hidden;
    box-shadow:0 5px 18px rgba(0,0,0,0.12);
}

.map-box iframe{
    width:100%;
    height:450px;
    border:none;
}

</style>
</head>

<body>

<!-- TOP HEADER -->

<div class="top-header">
    Free Express Shipping On Orders Above ₹999
</div>

<!-- HEADER -->

<div class="header">

    <div class="logo">
        POZARA
    </div>

    <div class="header-right">

        <a href="help.html">
            Help
        </a>
        <a href="about.html">
            About
        </a>
        <a href="contact.html"
        style="color:red;">
            Contact
        </a>

    </div>

</div>

<!-- CATEGORY BAR -->

<div class="main-categorybar">

    <div class="main-right">
        <a href="#">👩🏻Women</a>
        <a href="#">👨🏻Men</a>
        <a href="#">👶🏻Kids</a>
        <a href="#">Best Seller</a>
        <a href="#">Offers</a>
        <a href="#">New Arrivals</a>
        <a href="#">Trendings</a>

    </div>

    <!-- SEARCH -->

    <div class="main-center">

        <div class="searchbar">

            <input type="text"
            placeholder="search here ....">

            <button>
                search
            </button>

        </div>

    </div>

    <!-- ICONS -->

    <div class="main-left">

        <a href="profile.html">
            <i class="fa fa-user"></i>
        </a>

        <a href="wishlist.html">
            <i class="fa fa-heart"></i>
        </a>

        <a href="bag.html">
            <i class="fa fa-shopping-bag"></i>
        </a>

    </div>

</div>

<!-- HERO -->

<div class="contact-hero">

    <h1>Contact Support</h1>

    <p>
        We’d love to hear from you. Get in touch with POZARA anytime.
    </p>

</div>

<!-- CONTACT SECTION -->

<div class="contact-section">

    <!-- LEFT INFO -->

    <div class="contact-info">

        <!-- ADDRESS -->

        <div class="info-card">

            <i class="fa fa-location-dot"></i>

            <div class="info-text">

                <h2>Our Address</h2>

                <p>
                    POZARA Fashion Studio<br>
                    Ahmedabad, Gujarat, India
                </p>

            </div>

        </div>

        <!-- PHONE -->

        <div class="info-card">

            <i class="fa fa-phone"></i>

            <div class="info-text">

                <h2>Phone Number</h2>

                <p>
                    +91 9876543210<br>
                    +91 9999999999
                </p>

            </div>

        </div>

        <!-- EMAIL -->

        <div class="info-card">

            <i class="fa fa-envelope"></i>

            <div class="info-text">

                <h2>Email Address</h2>

                <p>
                    support@pozara.com<br>
                    help@pozara.com
                </p>

            </div>

        </div>

        <!-- HOURS -->

        <div class="info-card">

            <i class="fa fa-clock"></i>

            <div class="info-text">

                <h2>Working Hours</h2>

                <p>
                    Monday - Saturday<br>
                    9:00 AM - 9:00 PM
                </p>

            </div>

        </div>

    </div>

    <!-- RIGHT FORM -->

    <div class="contact-form">

        <h1>Send Message</h1>

        <!-- NAME -->

        <div class="input-group">

            <label>Full Name</label>

            <input type="text"
            placeholder="Enter your name">

        </div>

        <!-- EMAIL -->

        <div class="input-group">

            <label>Email Address</label>

            <input type="email"
            placeholder="Enter your email">

        </div>

        <!-- PHONE -->

        <div class="input-group">

            <label>Phone Number</label>

            <input type="text"
            placeholder="Enter phone number">

        </div>

        <!-- MESSAGE -->

        <div class="input-group">

            <label>Your Message</label>

            <textarea rows="6"
            placeholder="Write your message here..."></textarea>

        </div>

        <!-- BUTTON -->

        <button class="send-btn">

            Send Message

        </button>

    </div>

</div>

<!-- SOCIAL -->

<div class="social-section">

    <h1>Follow POZARA</h1>

    <div class="social-icons">

        <a href="#">
            <i class="fab fa-instagram"></i>
        </a>

        <a href="#">
            <i class="fab fa-facebook-f"></i>
        </a>

        <a href="#">
            <i class="fab fa-x-twitter"></i>
        </a>
    </div>

</div>

</div>

</body>
</html>
