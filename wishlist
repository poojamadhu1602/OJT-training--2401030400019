                <i class="fa fa-heart"></i>
            </div>

        </div>

        <div class="details">

            <h3>POZARA Oversized Tee</h3>

            <div class="type">
                Printed Casual T-Shirt
            </div>

            <div class="price">
                ₹999
            </div>

            <div class="buttons">

                <button class="cart">
                    Add To Bag
                </button>

                <button class="remove">
