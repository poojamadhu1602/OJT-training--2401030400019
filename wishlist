            </div>

        </div>

    </div>

    <!-- PRODUCT 3 -->

    <div class="card">

        <div class="image-box">

            <img src="https://copilot.microsoft.com/th/id/BCO.d50c6574-b3d2-4c69-b78f-6674519d3731.png">
            <div class="heart-icon">
                <i class="fa fa-heart"></i>
            </div>

        </div>

        <div class="details">

            <h3>POZARA Co-Ord Set</h3>

            <div class="type">
                Women Lounge Wear
            </div>

            <div class="price">
                ₹1999
            </div>

            <div class="buttons">

                <button class="cart">
                    Add To Bag
                </button>

                <button class="remove">
                    Remove
                </button>

            </div>

        </div>

    </div>

</div>

</body>
</html>
