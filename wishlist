                </button>

            </div>

        </div>

    </div>

    <!-- PRODUCT 2 -->

    <div class="card">

        <div class="image-box">

            <img src="https://copilot.microsoft.com/th/id/BCO.8e72da86-3139-4d4c-99ee-03060ee323d8.png">
            <div class="heart-icon">
                <i class="fa fa-heart"></i>
            </div>

        </div>

        <div class="details">

            <h3>POZARA Hoodie</h3>

            <div class="type">
                Women Street Fashion
            </div>

            <div class="price">
                ₹1499
            </div>

            <div class="buttons">

                <button class="cart">
                    Add To Bag
                </button>

                <button class="remove">
