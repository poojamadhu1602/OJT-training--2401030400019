<!DOCTYPE html>
<html>
<head>

<title>Ecommerce Website</title>

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
}
.top-header{
    background:black;
    color:white;
    text-align:center;
    padding:10px;
    font-size:14px;
}

header{
    background:white;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 50px;
    box-shadow:0 2px 5px rgba(0,0,0,0.2);
}

.logo{
    font-size:32px;
    font-weight:bold;
    color:#ff6600;
}

 .header-right a{
    text-decoration:none;
    color:black;
    margin:0 10px;
    font-weight:bold;
    transition:0.3s;
}

.header-right a:hover{
    color:#ff6600;
}
.categorybar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: black;
  padding: 7px 20px;
}
.categorybar .right {
  display: flex;
  align-items: center;
  gap: 25px;
}

.categorybar .right a {
  color: white;
  text-decoration: none;
  font-size: 15px;
  transition: color 0.2s ease;
}

.categorybar .right a:hover {
  color: red;
}
.categorybar .center {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-grow: 1;
}

.categorybar .center form {
  display: flex;
  align-items: center;
}

.categorybar .center input[type="text"] {
  padding: 6px;
  border: 1px solid white;
  border-radius: 4px 0 0 4px;
  outline: none;
}

.categorybar .center button {
  padding: 6px 12px;
  border: none;
  background-color: red;
  color: white;
  border-radius: 0 4px 4px 0;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

.categorybar .center button:hover {
  background-color: white;
  color: black;
}
.categorybar .left {
  display: flex;
  align-items: center;
  gap: 20px;
  justify-content: flex-end; 
  flex-shrink: 0; 
}

.categorybar .left a {
  color: white;
  font-size: 20px;
  transition: color 0.2s ease;
}

.categorybar .left a:hover {
  color: red;
}

.slider{
    width:100%;
    height:500px;
    overflow:hidden;
}

.slider img{
    width:100%;
    height:500px;
    object-fit:cover;
}


</style>
</head>

<body>

<div class="top-header">
    Free Express Shipping On Orders Above ₹999
</div>

<header>

<div class="logo">ShopZone</div>

<div class="header-right">
    <a href="#">Sign in/ Sign up</a>
    <a href="#">Help</a>
    <a href="#">About</a>
    <a href="#">Contact</a>
</div>

</header>
<div class="categorybar">

    <div class="right">
        <a href="#women">Women</a>
        <a href="#men">Men</a>
        <a href="#kids">Kids</a>
        <a href="#footware">Footware</a>
        <a href="#bag">Bag</a>
        <a href="#glasses">Glasses</a>
        <a href="#watch">Watch</a>
        <a href="#beauty">Beauty</a>
    </div>

    <div class="center">
        <div class="searchbar">
            <input type="text" placeholder="search here ....">
            <button type="submit">search</button>
        </div>
    </div>
    <div class="left">
        <a href="#profile"><i class="fa fa-user"></i></a>
    <a href="#wishlist"><i class="fa fa-heart"></i></a>
    <a href="#bag"><i class="fa fa-shopping-bag"></i></a>
    </div>
    </div>
  </div>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="slider">
    <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1400&auto=format&fit=crop" alt="Slider Image">
</div>
</body>
</html>
