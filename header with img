<!DOCTYPE html>
<html>
<head>

<title>Ecommerce Website</title>

<style>
  body{
      font-family:Arial, sans-serif;
      margin: 0;
    }

    .top-header {
      display: flex;
      background-color: black;
      align-items: center;
      padding: 1px 0px;
      background:black;
      color:white;
      font-size:14px;
    }

    .left {
      flex: 1;
      text-align: left;
    }

    .center {
      flex: 1;
      text-align: center;
    }
    .top-right {
      flex: 1;
      color: beige;
      text-align: center;
    }

    .top-header a {
      color: white;
      text-decoration: none;
    }

    .header {
      background-color: rgb(160, 155, 159);
      overflow: hidden;
      font-family: Arial, sans-serif;
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:15px 50px;
      box-shadow:0 2px 5px rgba(0,0,0,0.2);
    }

    .header .logo {
      text-decoration: none;
      float: left;
      padding: 10px 12px;
      cursor: pointer;
      display: block;
      font-size:32px;
      font-weight:bold;
      color:#ff6600;
    }

    .header .logo:hover {
      background-color: white;
      color: black;
      border-radius: 5px;
    }

    
    .header-right {
      float: right;
    }

    .header-right a {
      display: inline-block;
      color: black;
      text-align: center;
      padding: 10px 12px;
      text-decoration: none;
      font-size: 12px;
      margin:0 10px;
      font-weight:bold;
      transition:0.3s;
      gap: 25x;
    }

    .header-right a:hover {
      background-color: white;
      color: black;
      border-radius: 5px;
    }

    .header-right a.active {
      background-color: red;
      color: white;
      border-radius: 5px;
    }
    .categorybar{
    background:black;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:12px 30px;
}

.categorybar .right{
    display:flex;
    gap:30px;
    align-items:center;
    justify-content: flex-end;
    margin-right: 120px;
    flex-shrink: 0;
}

.categorybar .right a{
    color:white;
    text-decoration:none;
    font-size:16px;
    transition:0.3s;
}


.categorybar .right a:hover{
    color:red;
}
.categorybar .center {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-grow: 1;
}

.categorybar .center form {
  display: flex;
  align-items: center;
}

.categorybar .center input[type="text"] {
  padding: 6px;
  border: 1px solid white;
  border-radius: 4px 0 0 4px;
  outline: none;
}

.categorybar .center button {
  padding: 6px 12px;
  border: none;
  background-color: red;
  color: white;
  border-radius: 0 4px 4px 0;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

.categorybar .center button:hover {
  background-color: white;
  color: black;
}

.categorybar .left{
    display:flex;
    gap:25px;
    align-items:center;
}

.categorybar .left a{
    color:white;
    font-size:20px;
    transition:0.3s;
}
.categorybar .left a:hover {
  color:red;
}
.hero-banner{
    width: 100%;
    overflow: hidden;
}

.hero-banner img{
    width: 100%;
    height: auto;
    display: block;
}


</style>
</head>

<body>

<div class="top-header">
    Free Express Shipping On Orders Above ₹999
</div>

<header class="header">

<div class="logo">POZARA</div>

<div class="header-right">
    <a class="active" href="#">Sign in/ Sign up</a>
    <a href="#">Help</a>
    <a href="#">About</a>
    <a href="#">Contact</a>
</div>

</header>
<div class="categorybar">

    <div class="right">
        <a href="#women">👩🏻Women</a>
        <a href="#men">👨🏻Men</a>
        <a href="#kids">👶🏻Kids</a>
    </div>

    <div class="center">
        <div class="searchbar">
            <input type="text" placeholder="search here ....">
            <button type="submit">search</button>
        </div>
    </div>
    <div class="left">
    <a href="#profile"><i class="fa fa-user"></i></a>
    <a href="#wishlist"><i class="fa fa-heart"></i></a>
    <a href="#bag"><i class="fa fa-shopping-bag"></i></a>
</div>

</div> 

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<div class="hero-banner">
    <img src="https://copilot.microsoft.com/th/id/BCO.78d616f6-bc88-4292-8475-f5c45c5f68c6.png" alt="POZARA Clothing Brand">
</div>
</body>
</html>
