<!DOCTYPE html>
<html>
<head>
    <title>Nested List Example</title>
</head>
<body>

    <h2>Nested Ordered and Unordered List</h2>

    <ol>
        <li>Fruits
            <ul>
                <li>Apple</li>
                <li>Mango</li>
                <li>Banana</li>
            </ul>
        </li>

        <li>Vegetables
            <ul>
                <li>Potato</li>
                <li>Tomato</li>
                <li>Onion</li>
            </ul>
        </li>

        <li>Drinks
            <ol>
                <li>Tea</li>
                <li>Coffee</li>
                <li>Juice</li>
            </ol>
        </li>
    </ol>

</body>
</html>
