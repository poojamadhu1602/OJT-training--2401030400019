<!DOCTYPE html>
<html>
<head>

<title>POZARA Shopping Bag</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#F5F1EB;
}

/* TOP HEADER */

.top-header{
    background:black;
    color:white;
    text-align:center;
    padding:8px;
    font-size:14px;
}

/* HEADER */

.header{
    background:#F5F1EB;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 50px;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.logo{
    font-size:35px;
    font-weight:bold;
    color:#ff6600;
}

.header-right a{
    text-decoration:none;
    color:black;
    margin-left:20px;
    font-weight:bold;
    transition:0.3s;
}

.header-right a:hover{
    color:red;
}

/* CATEGORY BAR */

.main-categorybar{
    background:black;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:12px 30px;
}

.main-right{
    display:flex;
    gap:30px;
    align-items:center;
}

.main-right a{
    color:white;
    text-decoration:none;
    font-size:16px;
    font-weight:bold;
    transition:0.3s;
}

.main-right a:hover{
    color:red;
}

/* SEARCH */

.main-center{
    flex-grow:1;
    display:flex;
    justify-content:center;
}

.searchbar{
    display:flex;
}

.searchbar input{
    padding:8px 12px;
    border:none;
    outline:none;
    width:220px;
    border-radius:4px 0 0 4px;
}

.searchbar button{
    border:none;
    background:red;
    color:white;
    padding:8px 15px;
    cursor:pointer;
    font-weight:bold;
    border-radius:0 4px 4px 0;
}

.searchbar button:hover{
    background:white;
    color:black;
}

/* ICONS */

.main-left{
    display:flex;
    gap:25px;
}

.main-left a{
    color:white;
    font-size:20px;
    transition:0.3s;
}

.main-left a:hover{
    color:red;
    transform:scale(1.2);
}

/* ACTIVE BAG */

.bag-active{
    color:red !important;
    transform:scale(1.2);
}

/* PAGE TITLE */

.title{
    text-align:center;
    padding:40px 20px 10px;
}

.title h1{
    font-size:45px;
    margin-bottom:10px;
}

.title p{
    color:gray;
    font-size:18px;
}

/* CART SECTION */

.cart-container{
    width:90%;
    margin:40px auto 80px;
    display:flex;
    gap:40px;
    align-items:flex-start;
}

/* LEFT CART */

.cart-items{
    flex:2;
}

/* PRODUCT CARD */

.cart-card{
    background:white;
    border-radius:18px;
    padding:20px;
    margin-bottom:25px;
    display:flex;
    gap:25px;
    align-items:center;
    box-shadow:0 5px 18px rgba(0,0,0,0.12);
}

.image-box{
    position:relative;
}

.image-box img{
    width:180px;
    height:220px;
    object-fit:cover;
    border-radius:12px;
}

/* BRANDING */

.brand-print{
    position:absolute;
    bottom:15px;
    left:50%;
    transform:translateX(-50%);
    background:rgba(0,0,0,0.7);
    color:white;
    padding:6px 16px;
    border-radius:30px;
    font-size:15px;
    font-weight:bold;
    letter-spacing:2px;
}

/* DETAILS */

.details{
    flex:1;
}

.details h2{
    margin-top:0;
    font-size:28px;
}

.type{
    color:gray;
    margin:10px 0;
}

.price{
    color:red;
    font-size:28px;
    font-weight:bold;
    margin:15px 0;
}

/* QUANTITY */

.quantity{
    margin:20px 0;
}

.quantity button{
    width:35px;
    height:35px;
    border:none;
    background:black;
    color:white;
    font-size:18px;
    cursor:pointer;
    border-radius:5px;
}

.quantity span{
    margin:0 15px;
    font-size:18px;
    font-weight:bold;
}

/* BUTTONS */

.buttons{
    display:flex;
    gap:15px;
}

.remove,
.wishlist{
    padding:12px 20px;
    border:none;
    border-radius:7px;
    cursor:pointer;
    font-weight:bold;
    transition:0.3s;
}

.remove{
    background:red;
    color:white;
}

.remove:hover{
    background:black;
}

.wishlist{
    background:black;
    color:white;
}

.wishlist:hover{
    background:red;
}

/* ORDER SUMMARY */

.summary{
    flex:1;
    background:white;
    padding:30px;
    border-radius:18px;
    box-shadow:0 5px 18px rgba(0,0,0,0.12);
    position:sticky;
    top:30px;
}

.summary h2{
    margin-top:0;
    margin-bottom:25px;
}

.summary-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:18px;
    font-size:17px;
}

.total{
    font-size:24px;
    font-weight:bold;
    color:red;
    border-top:1px solid #ddd;
    padding-top:20px;
    margin-top:20px;
}

/* CHECKOUT */

.checkout-btn{
    width:100%;
    padding:15px;
    border:none;
    background:red;
    color:white;
    font-size:18px;
    font-weight:bold;
    border-radius:8px;
    cursor:pointer;
    margin-top:30px;
    transition:0.3s;
}

.checkout-btn:hover{
    background:black;
}

/* RESPONSIVE */

@media(max-width:900px){

.cart-container{
    flex-direction:column;
}

.cart-card{
    flex-direction:column;
    text-align:center;
}

}

</style>
</head>

<body>

<!-- TOP HEADER -->

<div class="top-header">
    Free Express Shipping On Orders Above ₹999
</div>

<!-- HEADER -->

<div class="header">

    <div class="logo">
        POZARA
    </div>

    <div class="header-right">

        <a href="#">Sign In</a>
        <a href="#">Help</a>
        <a href="#">About</a>
        <a href="#">Contact</a>

    </div>

</div>

<!-- MAIN CATEGORY BAR -->

<div class="main-categorybar">

    <div class="main-right">

        <a href="#">👩🏻Women</a>
        <a href="#">👨🏻Men</a>
        <a href="#">👶🏻Kids</a>
        <a href="#">Best Seller</a>
        <a href="#">Offers</a>
        <a href="#">New Arrivals</a>
        <a href="#">Trendings</a>

    </div>

    <!-- SEARCH -->

    <div class="main-center">

        <div class="searchbar">

            <input type="text"
            placeholder="search here ....">

            <button>
                search
            </button>

        </div>

    </div>

    <!-- ICONS -->

    <div class="main-left">

        <a href="profile.html">
            <i class="fa fa-user"></i>
        </a>

        <a href="wishlist.html">
            <i class="fa fa-heart"></i>
        </a>

        <a href="bag.html"
        class="bag-active">

            <i class="fa fa-shopping-bag"></i>

        </a>

    </div>

</div>

<!-- TITLE -->

<div class="title">

    <h1>Shopping Bag</h1>

    <p>Your Selected POZARA Fashion Collection</p>

</div>

<!-- CART -->

<div class="cart-container">

    <!-- LEFT SIDE -->

    <div class="cart-items">

        <!-- PRODUCT 1 -->

        <div class="cart-card">

            <div class="image-box">

                <img src="https://copilot.microsoft.com/th/id/BCO.acda7d68-a8bc-41e7-8020-acc9b0a3d7cd.png">
            </div>

            <div class="details">

                <h2>POZARA Oversized Tee</h2>

                <div class="type">
                    Printed Casual T-Shirt
                </div>

                <div class="price">
                    ₹999
                </div>
                <div class="sizes">
                     <span>S</span>
                </div>

                <div class="quantity">

                    <button>-</button>

                    <span>1</span>

                    <button>+</button>

                </div>

                <div class="buttons">

                    <button class="remove">
                        Remove
                    </button>

                    <button class="wishlist">
                        Move To Wishlist
                    </button>

                </div>

            </div>

        </div>

        <!-- PRODUCT 2 -->

        <div class="cart-card">

            <div class="image-box">

                <img src="https://copilot.microsoft.com/th/id/BCO.8e72da86-3139-4d4c-99ee-03060ee323d8.png">
            </div>

            <div class="details">

                <h2>POZARA Hoodie</h2>

                <div class="type">
                    Women Street Fashion
                </div>

                <div class="price">
                    ₹1499
                </div>
                <div class="sizes">
                     <span>S</span>
                </div>

                <div class="quantity">

                    <button>-</button>

                    <span>1</span>

                    <button>+</button>

                </div>

                <div class="buttons">

                    <button class="remove">
                        Remove
                    </button>

                    <button class="wishlist">
                        Move To Wishlist
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- RIGHT SUMMARY -->

    <div class="summary">

        <h2>Order Summary</h2>

        <div class="summary-row">

            <span>Subtotal</span>

            <span>₹2498</span>

        </div>

        <div class="summary-row">

            <span>Shipping</span>

            <span>Free</span>

        </div>

        <div class="summary-row">

            <span>Discount</span>

            <span>- ₹200</span>

        </div>

        <div class="summary-row total">

            <span>Total</span>

            <span>₹2298</span>

        </div>

        <button class="checkout-btn">
            Proceed To Checkout
        </button>

    </div>

</div>

</body>
</html>
