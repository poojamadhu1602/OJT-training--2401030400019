<!DOCTYPE html>
<html>
    <head>
        <title>Product detail table </title>
        <style>
            .product-table{
  padding: 30px;
  font-family: Arial, sans-serif;
}

.product-table h2{
  text-align: center;
  margin-bottom: 20px;
}

.product-table table{
  width: 100%;
  border-collapse: collapse;
  background-color: white;
}

.product-table th{
  background-color: black;
  color: white;
  padding: 12px;
}

.product-table td{
  border: 1px solid lightgray;
  padding: 12px;
  text-align: center;
}

.product-table tr:nth-child(even){
  background-color: #f2f2f2;
}

.product-table tr:hover{
  background-color: #ddd;
}

        </style>
    </head>
    <body>


<div class="product-table">

  <h2>Featured Products</h2>

  <table>
    <tr>
      <th>Product</th>
      <th>Category</th>
      <th>Price</th>
      <th>Stock</th>
      <th>Rating</th>
    </tr>

    <tr>
      <td>Leather Bag</td>
      <td>Bag</td>
      <td>$120</td>
      <td>Available</td>
      <td>⭐⭐⭐⭐⭐</td>
    </tr>

    <tr>
      <td>Sports Shoes</td>
      <td>Footwear</td>
      <td>$90</td>
      <td>Available</td>
      <td>⭐⭐⭐⭐</td>
    </tr>

    <tr>
      <td>Smart Watch</td>
      <td>Watch</td>
      <td>$150</td>
      <td>Limited</td>
      <td>⭐⭐⭐⭐⭐</td>
    </tr>

    <tr>
      <td>Beauty Kit</td>
      <td>Beauty</td>
      <td>$60</td>
      <td>Out of Stock</td>
      <td>⭐⭐⭐</td>
    </tr>
  </table>

</div>
    </body>
</html>
