<!DOCTYPE html>
<html>
<head>
<title>POZARA Registration Form</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#F5F1EB;
}

.header{
    background:black;
    color:white;
    padding:18px 50px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    font-size:35px;
    font-weight:bold;
    color:#ff6600;
}

.header a{
    color:white;
    text-decoration:none;
    margin-left:25px;
    font-size:15px;
    transition:0.3s;
}

.header a:hover{
    color:red;
}

.form-container{
    width:420px;
    background:white;
    margin:60px auto;
    padding:35px;
    border-radius:15px;
    box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

.form-container h2{
    text-align:center;
    margin-bottom:25px;
    color:#ff6600;
    font-size:32px;
}

.input-box{
    margin-bottom:20px;
}

.input-box label{
    display:block;
    margin-bottom:8px;
    font-weight:bold;
    color:#333;
}

.input-box input,
.input-box select{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:15px;
    outline:none;
    transition:0.3s;
    box-sizing:border-box;
}

.input-box input:focus,
.input-box select:focus{
    border-color:red;
    box-shadow:0 0 8px rgba(255,0,0,0.3);
}


.mobile-group{
    display:flex;
    gap:10px;
}

.mobile-group select{
    width:35%;
}

.mobile-group input{
    width:65%;
}

.register-btn{
    width:100%;
    padding:13px;
    border:none;
    background:red;
    color:white;
    font-size:17px;
    font-weight:bold;
    border-radius:8px;
    cursor:pointer;
    transition:0.3s;
}

.register-btn:hover{
    background:black;
    transform:scale(1.03);
}

.bottom-text{
    text-align:center;
    margin-top:18px;
    font-size:14px;
}

.bottom-text a{
    color:red;
    text-decoration:none;
    font-weight:bold;
}

/* SOCIAL LOGIN */

.social-login{
    margin-top:25px;
    text-align:center;
}

.social-login p{
    margin-bottom:15px;
    color:gray;
}

.social-icons a{
    text-decoration:none;
    color:white;
    margin:0 8px;
    width:42px;
    height:42px;
    line-height:42px;
    border-radius:50%;
    display:inline-block;
    font-size:18px;
    transition:0.3s;
}

.google{
    background:#DB4437;
}

.apple{
    background:black;
}

.facebook{
    background:#1877F2;
}

.social-icons a:hover{
    transform:scale(1.2);
}

</style>
</head>

<body>


<div class="header">

    <div class="logo">POZARA</div>

    <div>
        <a href="#">Home</a>
        <a href="#">Men</a>
        <a href="#">Women</a>
        <a href="#">Kids</a>
    </div>

</div>


<div class="form-container">

    <h2>Create Account</h2>

    <form>

        <div class="input-box">
            <label>Full Name</label>
            <input type="text" placeholder="Enter your full name" required>
        </div>

        <div class="input-box">
            <label>Email</label>
            <input type="email" placeholder="Enter your email" required>
        </div>


        <div class="input-box">
            <label>Password</label>
            <input type="password" placeholder="Create password" required>
        </div>

        <div class="input-box">
            <label>Gender</label>

            <select required>
                <option value="">Select Gender</option>
                <option>Male</option>
                <option>Female</option>
                <option>Other</option>
            </select>

        </div>


        <div class="input-box">

            <label>Mobile Number</label>

            <div class="mobile-group">

                <select required>
                    <option>+91</option>
                    <option>+1</option>
                    <option>+44</option>
                    <option>+971</option>
                </select>

                <input type="tel" placeholder="Enter mobile number" required>

            </div>

        </div>


        <button class="register-btn">
            Register
        </button>

    </form>


    <div class="bottom-text">
        Already have an account?
        <a href="#">Sign In</a>
    </div>

    <div class="social-login">

        <p>OR Register With</p>

        <div class="social-icons">

            <a href="#" class="google">
                <i class="fab fa-google"></i>
            </a>

            <a href="#" class="apple">
                <i class="fab fa-apple"></i>
            </a>

            <a href="#" class="facebook">
                <i class="fab fa-facebook-f"></i>
            </a>

        </div>

    </div>

</div>

</body>
</html>
